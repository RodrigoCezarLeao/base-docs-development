# ──────────────────────────────────────────────────────────────────────────────
# Server-side environment for ONE project on ONE VPS (dev OR prod).
#
# This file lives ONLY on the VPS at /opt/apps/<project>/.env — it is created once
# during provisioning and NEVER committed or pushed by CI. The deploy pipeline only
# updates IMAGE_TAG; every secret below stays on the host.
#
# Copy to .env and fill in real values:  cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# Identity / registry --------------------------------------------------------
PROJECT=temperature            # used for image name, paths and container name
GHCR_OWNER=your-github-user    # lowercase owner/org that owns the GHCR image
IMAGE_TAG=latest               # updated by the deploy pipeline to the commit SHA
API_PORT=8080                  # dedicated loopback host port (unique per project on the VPS)

# Database (PostgreSQL on the host) ------------------------------------------
DB_NAME=temperature_dev
DB_USER=temperature_dev
DB_PASSWORD=change-me-strong-password

# Application ----------------------------------------------------------------
# Origin(s) allowed by CORS — the public site URL for this environment.
CORS_ORIGINS=https://dev.example.com
# Only required by projects that use JWT (e.g. docmap). Min 32 chars. Leave blank otherwise.
JWT_SECRET=
